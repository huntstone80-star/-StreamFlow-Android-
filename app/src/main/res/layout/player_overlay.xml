<?xml version="1.0" encoding="utf-8"?>
<!-- Novafame Player Overlay -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Top info bar -->
    <LinearLayout
        android:id="@+id/top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingTop="20dp"
        android:paddingBottom="16dp"
        android:paddingLeft="32dp"
        android:paddingRight="32dp"
        android:background="@drawable/player_gradient_top">

        <TextView
            android:id="@+id/btn_back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:gravity="center"
            android:textSize="22sp"
            android:textColor="#FFFFFF"
            android:text="&#x2715;"
            android:background="@drawable/novafame_btn_small"
            android:focusable="true"
            android:nextFocusDown="@+id/btn_play_pause" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginLeft="20dp">

            <TextView
                android:id="@+id/player_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="Novafame"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/player_episode_counter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#888888"
                android:textSize="13sp"
                android:layout_marginTop="2dp"
                android:text="" />
        </LinearLayout>
    </LinearLayout>

    <!-- Center play/pause animation -->
    <ImageView
        android:id="@+id/play_pause_center"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_gravity="center"
        android:visibility="gone"
        android:background="@drawable/novafame_btn_large"
        android:padding="20dp"
        android:scaleType="centerInside" />

    <!-- Bottom controls panel -->
    <LinearLayout
        android:id="@+id/bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:paddingTop="20dp"
        android:paddingBottom="28dp"
        android:paddingLeft="40dp"
        android:paddingRight="40dp"
        android:background="@drawable/player_gradient_bottom">

        <!-- Progress row -->
        <RelativeLayout
            android:id="@+id/progress_row"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp">

            <FrameLayout
                android:id="@+id/progress_container"
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:layout_centerVertical="true"
                android:background="#33FFFFFF"
                android:layout_marginLeft="4dp"
                android:layout_marginRight="4dp">

                <View
                    android:id="@+id/progress_buffered"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:background="#3300E5FF" />

                <View
                    android:id="@+id/progress_played"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:background="#00E5FF" />

                <View
                    android:id="@+id/progress_thumb"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:layout_gravity="center_vertical|left"
                    android:background="@drawable/thumb_circle"
                    android:translationX="-6dp"
                    android:visibility="visible" />
            </FrameLayout>
        </RelativeLayout>

        <!-- Time row -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/current_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:text="0:00"
                android:fontFamily="sans-serif" />

            <TextView
                android:id="@+id/total_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#888888"
                android:textSize="12sp"
                android:layout_alignParentRight="true"
                android:text="0:00"
                android:fontFamily="sans-serif" />
        </RelativeLayout>

        <!-- Controls row -->
        <LinearLayout
            android:id="@+id/controls_row"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@drawable/novafame_glass_panel"
            android:padding="6dp">

            <TextView
                android:id="@+id/btn_previous"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:gravity="center"
                android:textSize="18sp"
                android:textColor="#FFFFFF"
                android:text="\u23EE"
                android:background="@drawable/novafame_btn_small"
                android:focusable="true"
                android:nextFocusLeft="@id/btn_back"
                android:nextFocusRight="@id/btn_rewind" />

            <TextView
                android:id="@+id/btn_rewind"
                android:layout_width="52dp"
                android:layout_height="44dp"
                android:gravity="center"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:text="\u23EA 10s"
                android:layout_marginLeft="8dp"
                android:background="@drawable/novafame_btn_small"
                android:focusable="true"
                android:nextFocusLeft="@id/btn_previous"
                android:nextFocusRight="@id/btn_play_pause" />

            <TextView
                android:id="@+id/btn_play_pause"
                android:layout_width="56dp"
                android:layout_height="44dp"
                android:gravity="center"
                android:textSize="22sp"
                android:textColor="#FFFFFF"
                android:text="\u25B6"
                android:layout_marginLeft="12dp"
                android:layout_marginRight="12dp"
                android:background="@drawable/novafame_btn_play"
                android:focusable="true"
                android:nextFocusLeft="@id/btn_rewind"
                android:nextFocusRight="@id/btn_forward" />

            <TextView
                android:id="@+id/btn_forward"
                android:layout_width="52dp"
                android:layout_height="44dp"
                android:gravity="center"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:text="30s \u23E9"
                android:layout_marginRight="8dp"
                android:background="@drawable/novafame_btn_small"
                android:focusable="true"
                android:nextFocusLeft="@id/btn_play_pause"
                android:nextFocusRight="@id/btn_next" />

            <TextView
                android:id="@+id/btn_next"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:gravity="center"
                android:textSize="18sp"
                android:textColor="#FFFFFF"
                android:text="\u23ED"
                android:background="@drawable/novafame_btn_small"
                android:focusable="true"
                android:nextFocusLeft="@id/btn_forward"
                android:nextFocusRight="@id/btn_previous" />
        </LinearLayout>

        <!-- Hint text -->
        <TextView
            android:id="@+id/hint_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="10dp"
            android:textColor="#555555"
            android:textSize="11sp"
            android:text="\u2190\u2192 Seek   \u2191\u2193 Volume   OK Play   \u23CE Back"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Volume indicator -->
    <LinearLayout
        android:id="@+id/volume_indicator"
        android:layout_width="40dp"
        android:layout_height="140dp"
        android:layout_gravity="right|center_vertical"
        android:layout_marginRight="20dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/novafame_glass_panel"
        android:padding="8dp"
        android:visibility="gone">

        <FrameLayout
            android:layout_width="4dp"
            android:layout_height="90dp"
            android:background="#33FFFFFF">

            <View
                android:id="@+id/volume_level"
                android:layout_width="match_parent"
                android:layout_height="45dp"
                android:layout_gravity="bottom"
                android:background="#00E5FF" />
        </FrameLayout>

        <TextView
            android:id="@+id/volume_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:layout_marginTop="6dp"
            android:text="50" />
    </LinearLayout>

    <!-- Episode change card -->
    <FrameLayout
        android:id="@+id/episode_change_overlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/player_gradient_top"
        android:padding="20dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/episode_change_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#00E5FF"
                android:textSize="16sp"
                android:text="Next Episode"
                android:fontFamily="sans-serif-medium" />

            <TextView
                android:id="@+id/episode_change_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="#C084FC"
                android:textSize="13sp"
                android:text="" />
        </LinearLayout>
    </FrameLayout>
</FrameLayout>
